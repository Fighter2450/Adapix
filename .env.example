# Adapix v0 environment configuration
# Copy this file to .env and fill in real values. Never commit .env.

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-...
ADAPIX_MODEL=claude-sonnet-4-6

# --- Twilio SMS (required for SMS channel) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# --- Resend email (required for email channel) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@adapix.com

# --- Vapi AI voice calls (required for the calling channel) ---
# Create an account at vapi.ai, buy a phone number, then copy these from the
# dashboard. VAPI_PHONE_NUMBER_ID is the ID of the number that PLACES calls.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# ElevenLabs voice used for the AI. Change to taste in the Vapi voice library.
VAPI_VOICE_PROVIDER=11labs
VAPI_VOICE_ID=burt
VAPI_MODEL_PROVIDER=anthropic
# Business name spoken in the required AI-disclosure opening line.
BUSINESS_NAME=our office

# --- Database ---
DATABASE_URL=sqlite:///./adapix.db

# --- Admin UI HTTP Basic auth ---
# Leave both blank in dev to disable auth. ALWAYS set both in production.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Webhook security ---
# Set true ONLY for local dev without Twilio. Never true in production.
SKIP_TWILIO_VERIFICATION=false
# When behind a proxy / ngrok, set the public-facing URL Twilio is hitting.
# Required for signature verification because Twilio signs the URL it sent to.
PUBLIC_BASE_URL=
