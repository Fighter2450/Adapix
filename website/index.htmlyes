<script>
// Scroll reveal
const io = new IntersectionObserver((entries)=>{
  for (const e of entries){
    if (e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }
  }
}, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// Cycle the OLED text on the hero device
const oledMsgs = ["Adapix · idle","Drafting reply…","3 drafts ready","Maria K. flagged"];
const oledEl1 = document.getElementById('oled1');
let mi = 0;
function cycleOled(){
  if (!oledEl1) return;
  oledEl1.style.opacity = '0';
  setTimeout(()=>{
    mi = (mi + 1) % oledMsgs.length;
    oledEl1.textContent = oledMsgs[mi];
    oledEl1.style.opacity = '1';
  }, 280);
}
if (oledEl1) setInterval(cycleOled, 2800);

// Reservation form — fall back to a "thanks" message if Netlify forms isn't picked up
function handleReserve(e){
  // If served from Netlify with form detection on, the POST handles it.
  // If served from a static file:// or any other host, just show the thanks state.
  const isLocal = window.location.protocol === 'file:' || window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost';
  if (isLocal){
    e.preventDefault();
    document.getElementById('reserve-success').classList.add('on');
    e.target.style.display='none';
  }
  // Otherwise let it submit to Netlify normally.
}
</script>

</body>
</html>
