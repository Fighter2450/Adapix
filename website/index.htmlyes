    <a href="#reserve" class="btn btn-primary">Reserve yours</a>
  </div>
</section>

<!-- ===== BUY BANNER ===== -->
<section class="buy-banner" id="reserve">
  <div class="eyebrow">Last 50 spots</div>
  <h2>Bring AI to your practice.<br>Start tomorrow.</h2>
  <p class="kicker">First 50 practices get $300 off the device and locked-in software pricing for life. Drop your email — we'll hold your spot.</p>
  <form class="reserve-form" name="reserve" method="POST" data-netlify="true" onsubmit="handleReserve(event)">
    <input type="hidden" name="form-name" value="reserve">
    <input type="email" name="email" placeholder="you@yourpractice.com" required>
    <button type="submit" class="btn btn-primary">Reserve Adapt 1.0</button>
  </form>
  <div class="reserve-success" id="reserve-success">Thanks — you're on the list. We'll be in touch the moment Adapt 1.0 is ready to ship.</div>
</section>

